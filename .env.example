# aisstream.io — free at https://aisstream.io/authenticate
AISSTREAM_API_KEY=your_aisstream_key_here

# Pinata JWT — free 1GB at https://app.pinata.cloud
PINATA_JWT=your_pinata_jwt_here

# Ocean Protocol — your MetaMask wallet private key (Polygon network)
# NEVER commit this file with real values
OCEAN_PRIVATE_KEY=your_metamask_private_key_here
OCEAN_NETWORK=polygon  # or mumbai for testnet

# Collector settings
BOUNDING_BOXES=[[[-90,-180],[90,180]]]   # whole world; narrow for lower volume
FLUSH_INTERVAL_SECONDS=600              # write Parquet every 10 min
FLUSH_MAX_MESSAGES=50000               # or every 50k messages

# Storage paths (local or Akash persistent volume)
DATA_DIR=/data/raw
PROCESSED_DIR=/data/processed
